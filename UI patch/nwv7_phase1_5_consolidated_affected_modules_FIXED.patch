+              <div style={{ flex: 1 }}>
+                <div style={{ fontSize: '0.85rem', fontWeight: 600, color: 'var(--text-primary)', marginBottom: 3 }}>{ipo.name}</div>
+                <div style={{ fontSize: '0.7rem', color: 'var(--text-muted)' }}>{ipo.openDate || 'TBA'}{ipo.closeDate ? ` → ${ipo.closeDate}` : ''}{ipo.isSME ? ' · SME' : ''}</div>
+              </div>
