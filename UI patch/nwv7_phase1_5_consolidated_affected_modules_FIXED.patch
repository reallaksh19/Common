+          <h3 style={{ margin: 0, fontSize: '0.88rem', fontWeight: 700, color: 'var(--text-primary)' }}>IPO Tracker</h3>
+        </div>
+        <div style={{ fontSize: '0.62rem', color: 'var(--text-muted)' }}>Upcoming, live and recent issues</div>
