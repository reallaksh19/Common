+import React from 'react';
+
+function statusStyle(status) {
+  if (status === 'live' || status === 'open') return { bg: 'rgba(63,185,80,0.15)', color: 'var(--accent-success)', border: 'rgba(63,185,80,0.4)', label: 'Live' };
+  if (status === 'recent' || status === 'closed') return { bg: 'rgba(255,255,255,0.04)', color: 'var(--text-muted)', border: 'var(--bsoft)', label: 'Closed' };
+  return { bg: 'rgba(88,166,255,0.12)', color: '#90bfff', border: 'rgba(88,166,255,0.3)', label: 'Upcoming' };
+}
+
+export default function IpoList({ upcoming = [], live = [], recent = [] }) {
