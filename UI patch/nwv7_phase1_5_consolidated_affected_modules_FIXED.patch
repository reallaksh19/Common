+        <span style={{ width: 7, height: 7, borderRadius: '50%', background: dotColor }} />
+      </div>
+      <div style={{ fontSize: '0.67rem', color: 'var(--text-muted)', fontFamily: 'Roboto Mono, monospace' }}>{countText}</div>
+      <div style={{ height: 3, borderRadius: 2, background: 'rgba(255,255,255,0.05)', overflow: 'hidden', marginTop: 'auto' }}>
+        <span style={{ display: 'block', height: '100%', borderRadius: 2, width: `${percent}%`, background: status === 'err' ? 'var(--accent-danger)' : 'var(--accent-primary)' }} />
