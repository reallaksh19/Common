+  const net = Number(data.net || 0);
+  const positive = net >= 0;
+  return (
+    <div style={{ padding: '11px 12px', borderRadius: 12, background: 'rgba(255,255,255,0.025)', border: '1px solid var(--bsoft)' }}>
+      <div style={{ fontSize: '0.75rem', fontWeight: 700, color: 'var(--text-secondary)', marginBottom: 8, letterSpacing: '0.06em' }}>{title}</div>
+      <div style={{ display: 'flex', justifyContent: 'space-between', padding: '4px 0', borderBottom: '1px solid rgba(255,255,255,0.04)', fontSize: '0.78rem' }}><span style={{ color: 'var(--text-muted)' }}>Buy</span><strong style={{ color: 'var(--accent-success)' }}>₹{data.buy ?? '--'} Cr</strong></div>
+      <div style={{ display: 'flex', justifyContent: 'space-between', padding: '4px 0', borderBottom: '1px solid rgba(255,255,255,0.04)', fontSize: '0.78rem' }}><span style={{ color: 'var(--text-muted)' }}>Sell</span><strong style={{ color: '#ff8c96' }}>₹{data.sell ?? '--'} Cr</strong></div>
+      <div style={{ display: 'flex', justifyContent: 'space-between', padding: '6px 0 4px', fontSize: '0.78rem' }}><span style={{ color: 'var(--text-muted)' }}>Net</span><strong style={{ color: positive ? 'var(--accent-success)' : '#ff8c96' }}>₹{data.net ?? '--'} Cr</strong></div>
+    </div>
+  );
+}
+
+export default function FlowCard({ fii = {}, dii = {}, date = '' }) {
+  if (!Object.keys(fii).length && !Object.keys(dii).length) return null;
+  return (
+    <div style={{ borderRadius: 16, border: '1px solid var(--border-default)', background: 'linear-gradient(180deg,rgba(22,27,34,0.5),rgba(14,18,24,0.5))', marginBottom: 12, overflow: 'hidden' }}>
+      <div style={{ padding: '12px 14px 10px', borderBottom: '1px solid rgba(255,255,255,0.04)', display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
+        <div>
+          <div style={{ fontSize: '0.6rem', fontWeight: 700, letterSpacing: '0.15em', textTransform: 'uppercase', color: 'var(--text-muted)', marginBottom: 2 }}>Flows</div>
+          <h3 style={{ margin: 0, fontSize: '0.88rem', fontWeight: 700, color: 'var(--text-primary)' }}>FII / DII Activity</h3>
+        </div>
+        <div style={{ fontSize: '0.62rem', color: 'var(--text-muted)' }}>{date || 'Latest available'}</div>
+      </div>
+      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 8, padding: '10px 12px 12px' }}>
+        <FlowBox title="FII" data={fii} />
+        <FlowBox title="DII" data={dii} />
+      </div>
+    </div>
+  );
+}

