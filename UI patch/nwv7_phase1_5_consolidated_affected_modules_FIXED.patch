+import React, { useMemo } from 'react';
+import { Link } from 'react-router-dom';
+import Header from '../components/Header';
+import InsightPageView from '../ui/insight/InsightPageView';
+import { useNews } from '../context/NewsContext';
+import { useMediaQuery } from '../hooks/useMediaQuery';
+import { shortenSourceLabel } from '../utils/storyMeta';
+import { analyzeArticleSentiment } from '../utils/sentimentAnalyzer';
+import { getRuntimeCapabilities } from '../runtime/runtimeCapabilities';
+
+function formatAgeLabel(value) {
+  const timestamp = new Date(value).getTime();
+  if (!Number.isFinite(timestamp) || timestamp <= 0) return 'Unknown';
+  const diffMs = Date.now() - timestamp;
+  const mins = Math.max(1, Math.round(diffMs / 60000));
+  if (mins < 60) return `${mins}m ago`;
+  const hrs = Math.round(mins / 60);
+  if (hrs < 24) return `${hrs}h ago`;
+  const days = Math.round(hrs / 24);
+  return `${days}d ago`;
+}
+
+function normalizeImpact(score, maxScore) {
+  const safeScore = Number(score || 0);
+  const safeMax = Number(maxScore || 0);
+  if (!Number.isFinite(safeScore) || safeMax <= 0) return 0.42;
+  const raw = safeScore / safeMax;
+  return Math.max(0.18, Math.min(0.98, raw));
+}
+
+function buildSourceComparisons(item) {
+  const sources = Array.isArray(item.allSources) && item.allSources.length ? item.allSources : [item.source].filter(Boolean);
+  return sources.slice(0, 5).map((src, idx) => ({
+    name: shortenSourceLabel(src),
+    angle: idx === 0 ? 'same' : 'diff',
+    desc: idx === 0 ? 'Primary source carried in the ranked story cluster' : 'Additional confirming or alternate-angle coverage',
+    time: formatAgeLabel(item.publishedAt)
+  }));
+}
+
+function buildAngles(item, audit) {
+  const angles = [];
+  if (item.section) {
+    angles.push({ cat: 'Section', txt: `Primary classification leans toward ${String(item.section).replace(/-/g, ' ')}.` });
+  }
+  if (item.sourceCount > 1) {
+    angles.push({ cat: 'Consensus', txt: `${item.sourceCount} unique sources contribute to this ranked story.` });
+  }
+  if (audit?.consensus?.badge) {
+    angles.push({ cat: 'Validation', txt: `Cross-source validation badge ${audit.consensus.badge} with ${audit.consensus.count} corroborating source signals.` });
+  }
+  if (audit?.relevance?.matches?.length) {
+    angles.push({ cat: 'Audience Fit', txt: `Matched tracked interests or followed topics: ${audit.relevance.matches.slice(0, 4).join(', ')}.` });
+  }
+  if (audit?.anomaly?.badge) {
+    angles.push({ cat: 'Anomaly', txt: `Audit flagged this story as ${audit.anomaly.type}.` });
+  }
+  if (item.description) {
+    angles.push({ cat: 'Context', txt: item.description.length > 120 ? `${item.description.slice(0, 117)}…` : item.description });
+  }
+  return angles.slice(0, 5);
+}
+
+function buildSentiment(item) {
+  const res = analyzeArticleSentiment(item.title || item.headline || '', item.description || item.summary || '');
+  const comp = Math.max(-0.35, Math.min(0.35, res.comparative || 0));
+  const pos = Math.max(5, Math.min(90, Math.round(34 + comp * 90)));
+  const neg = Math.max(5, Math.min(90, Math.round(34 - comp * 90)));
+  const neu = Math.max(0, 100 - pos - neg);
+  return { pos, neg, neu };
+}
+
+function buildCoverage(newsData, loadedSections, errors) {
+  const sections = [
+    ['world', 'World'],
+    ['india', 'India'],
+    ['chennai', 'Tamil Nadu'],
+    ['trichy', 'Trichy'],
+    ['local', 'Muscat'],
+    ['business', 'Business'],
+    ['technology', 'Tech'],
+    ['social', 'Social'],
+    ['entertainment', 'Entertainment']
+  ];
+  return sections.map(([id, name]) => {
+    const articles = Array.isArray(newsData[id]) ? newsData[id] : [];
+    const loaded = loadedSections.includes(id);
+    const hasError = Boolean(errors?.[id]);
+    return {
+      id,
+      name,
+      status: hasError ? 'err' : loaded ? 'ok' : 'q',
+      countText: hasError ? 'error' : loaded ? `${articles.length} items` : 'queued',
+      percent: hasError ? 8 : loaded ? Math.min(100, Math.max(12, articles.length * 10)) : 25
+    };
+  });
+}
+
+function buildStats(rankedStories, coverage) {
+  const breaking = rankedStories.filter((s) => s.isBreaking).length;
+  const consensus = rankedStories.filter((s) => s.sourceCount > 1).length;
+  const live = coverage.filter((c) => c.status === 'ok').length;
+  return [
+    { key: 'ranked', label: 'Ranked', value: rankedStories.length, tone: 'info' },
+    { key: 'breaking', label: 'Breaking', value: breaking, tone: 'warn' },
+    { key: 'consensus', label: 'Consensus', value: consensus, tone: 'good' },
+    { key: 'sections', label: 'Sections', value: `${live}/${coverage.length}`, tone: 'teal' },
+    { key: 'fresh', label: 'Fresh', value: rankedStories[0]?.ageLabel?.replace(' ago', '') || '0m', tone: 'mute' }
+  ];
+}
+
+function buildPulse(rankedStories, coverage) {
+  const avgImpact = rankedStories.length ? rankedStories.reduce((sum, story) => sum + story.impact, 0) / rankedStories.length : 0.35;
+  const signalScore = Math.round(Math.min(98, Math.max(22, avgImpact * 100)));
+  const liveSections = coverage.filter((c) => c.status === 'ok').length;
+  const breakingCount = rankedStories.filter((s) => s.isBreaking).length;
+  const toneLabel = rankedStories.filter((s) => s.sentiment.neg > s.sentiment.pos).length > rankedStories.length / 2 ? 'cautious' : 'positive';
+  const runtime = getRuntimeCapabilities();
+  return {
+    signalScore,
+    toneLabel,
+    breakingCount,
+    freshnessLabel: rankedStories[0]?.ageLabel || 'now',
+    coveredSections: liveSections,
+    totalSections: coverage.length,
+    nextRefreshLabel: '05:00',
+    dataMode: runtime.runtimeLabel === 'static-host' ? 'snapshot' : 'live'
+  };
+}
+
+function mapInsightModel(newsData, breakingNews, loadedSections, errors, auditResults) {
+  const candidates = Array.isArray(newsData.frontPage) && newsData.frontPage.length
+    ? newsData.frontPage
+    : ['world', 'india', 'chennai', 'trichy', 'local', 'business', 'technology', 'social', 'entertainment']
+        .flatMap((key) => Array.isArray(newsData[key]) ? newsData[key] : []);
+
+  const deduped = [];
+  const seen = new Set();
+  for (const item of candidates) {
+    const key = String(item.hiddenKey || item.canonicalId || item.id || item.link || item.title || '').trim();
+    if (!key || seen.has(key)) continue;
+    seen.add(key);
+    deduped.push(item);
+  }
+
+  const sorted = [...deduped].sort((a, b) => (b.impactScore || 0) - (a.impactScore || 0));
+  const maxScore = sorted[0]?.impactScore || 1;
+  const top = sorted.slice(0, 5);
+
+  const rankedStories = top.map((item, index) => {
+    const audit = auditResults?.[item.id] || null;
+    const sourceTags = (Array.isArray(item.allSources) && item.allSources.length ? item.allSources : [item.source].filter(Boolean))
+      .slice(0, 4)
+      .map(shortenSourceLabel);
+    const sourceCount = item.sourceCount || sourceTags.length || 1;
+    return {
+      id: item.id,
+      rank: index + 1,
+      source: shortenSourceLabel(item.source),
+      ageLabel: formatAgeLabel(item.publishedAt),
+      sourceCount,
+      isBreaking: Boolean(item.isBreaking || (item.breakingScore && item.breakingScore > 1.5)),
+      impact: normalizeImpact(item.impactScore, maxScore),
+      title: item.title || item.headline || 'Untitled story',
+      summary: item.description || item.summary || 'No summary available for this story.',
+      criticsTake: audit?.relevance?.matches?.length
+        ? `Audience-fit matches detected: ${audit.relevance.matches.slice(0, 4).join(', ')}.`
+        : sourceCount > 2
+          ? 'Multiple outlets are converging on this topic, suggesting a durable top-story thread.'
+          : null,
+      sources: buildSourceComparisons(item),
+      angles: buildAngles(item, audit),
+      sentiment: buildSentiment(item),
+      sourceTags,
+      hiddenDuplicateCount: Math.max(0, sourceCount - sourceTags.length),
+      weakTree: sourceCount <= 1,
+      rising: index < 2 || (item.breakingScore || 0) > 1.5,
+      snapshotDots: [
+        { key: 'now', on: index < 3 },
+        { key: '-4h', on: sourceCount > 1 },
+        { key: '-12h', on: Boolean(audit?.consensus?.count && audit.consensus.count > 1) },
+        { key: '-24h', on: Boolean(item.clusteredItems && item.clusteredItems > 1) }
+      ]
+    };
+  });
+
+  const coverage = buildCoverage(newsData, loadedSections, errors);
+  return {
+    pulse: buildPulse(rankedStories, coverage),
+    stats: buildStats(rankedStories, coverage),
+    rankedStories,
+    coverage,
+    breakingCount: breakingNews?.length || 0
+  };
+}
+
+export default function InsightPage() {
+  const { newsData, loading, refreshNews, breakingNews, loadedSections, errors, auditResults } = useNews();
+  const { isWebView } = useMediaQuery();
+  const model = useMemo(() => mapInsightModel(newsData, breakingNews, loadedSections, errors, auditResults), [newsData, breakingNews, loadedSections, errors, auditResults]);
+
+  const headerActions = (
+    <div className="header__actions">
+      <button type="button" className="header__action-btn" onClick={() => refreshNews()} title="Refresh Insight">🔄</button>
+      <Link to="/settings" className="header__action-btn">⚙️</Link>
+    </div>
+  );
+
+  return (
+    <div className={`page-container ${isWebView ? 'page-container--desktop' : ''}`}>
+      <Header title="Insight" actions={headerActions} loadingPhase={loading ? 1 : 3} />
+      <main className={`main-content ${isWebView ? 'main-content--desktop' : ''}`} style={{ padding: '16px' }}>
+        <InsightPageView pulse={model.pulse} stats={model.stats} rankedStories={model.rankedStories} coverage={model.coverage} />
+      </main>
+    </div>
+  );
+}

